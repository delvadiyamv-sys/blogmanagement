<%-include("./parcials/header.ejs") %>
  <div class="container">
    <img src="/uploads/logo-01.png" alt="Tech_InfoSys Banner" class="img-fluid mx-4 mt-4 mb-4">
    <img src="/uploads/banner.jpg" alt="Tech_InfoSys Banner" class="img-fluid mx-4 mt-4 mb-4">
  </div>

  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top 0">

    <div class="container ">
      <div class="d-flex gap-3 me-3">
        <a href="#" class="text-light social-icon"><i class="fab fa-facebook-f"></i></a>
        <a href="#" class="text-light social-icon"><i class="fab fa-twitter"></i></a>
        <a href="#" class="text-light social-icon"><i class="fab fa-instagram"></i></a>
        <a href="#" class="text-light social-icon"><i class="fab fa-youtube"></i></a>
      </div>


      <a class="navbar-brand" href="#!">Techno_infoSys</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation"><span
          class="navbar-toggler-icon"></span></button>
      <div class="collapse navbar-collapse" id="navbarSupportedContent">
        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link active" aria-current="page" href="/">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/about">About_us</a></li>
          <li class="nav-item"><a class="nav-link" href="/contact">Contact_us</a></li>
          <% if (user) { %>
            <li class="nav-item"><a class="nav-link" href="/profile">
                <i class="fa-solid fa-user"></i>
                <%= user.name %>
              </a></li>
            <li class="nav-item"><a class="nav-link" href="/logout">Logout</a></li>
            <% } else { %>
              <li class="nav-item"><a class="nav-link" href="/login">Login</a></li>
              <% } %>

        </ul>
      </div>
    </div>
  </nav>



  <div id="carouselExampleInterval" class="carousel slide my-3 mx-3 mx-lg-3" data-bs-ride="carousel">
    <div class="carousel-inner">
      <div class="carousel-item active" data-bs-interval="3000">
        <img src="<%= newAd[0].image %>" class="d-block w-100" alt="..." style="height: 400px; object-fit: cover;">
      </div>
      <div class="carousel-item" data-bs-interval="2000">
        <img src="<%= newAd[1].image %>" class="d-block w-100" alt="..." style="height: 400px; object-fit: cover;">
      </div>
      <div class="carousel-item">
        <img src="<%= newAd[2].image %>" class="d-block w-100" alt="..." style="height: 400px; object-fit: cover;">
      </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleInterval" data-bs-slide="prev">
      <span class="carousel-control-prev-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleInterval" data-bs-slide="next">
      <span class="carousel-control-next-icon" aria-hidden="true"></span>
      <span class="visually-hidden">Next</span>
    </button>
  </div>


  <div class="container-fluid my-5 px-lg-4" id="runpost">
    <div class="row mx-lg-4">

      <!-- Posts Section -->
      <div class="col-12 col-lg-8 px-lg-4 ">
        <div class="row">
          <% if(newPost.length> 0)
            for(let i = (newPost.length - 1); i >= 0; i--) { %>

            <!-- Post -->
            <div class="col-12 col-md-6 mb-4 ">
              <div class="card h-100 ">
                <img src="<%= newPost[i].image %>" class="card-img-top img-fluid" alt="Post Image"
                  style="height: 250px; object-fit: cover;">
                <div class="card-body">
                  <h5>
                    <%= newPost[i].title.substring(0, 70) %>
                  </h5>
                  <p>
                    <%= newPost[i].content.substring(0, 90) %>...
                      <a href="/post/<%= newPost[i]._id %>" class="btn btn-link">Read More</a>
                  </p>
                </div>
              </div>
            </div>


            <!-- Ads after every 4 posts -->
            <% if ((i + 1)===4) { %>
              <div class="col-12 mb-4">
                <small class="text-muted">Advertisement:</small>
                <div class="bg-light text-center p-4">

                  <img src="uploads/blog01.jpg" alt="Ads Banner 1" class="img-fluid mt-2"
                    style="max-height: 200px; width: 100%; object-fit: cover;">
                </div>
              </div>
              <% } %>

                <% if ((i + 1)===10) { %>
                  <div class="col-12 mb-4">
                    <small class="text-muted">Advertisement:</small>
                    <div class="bg-light text-center p-4">

                      <img src="uploads/blog01.jpg" alt="Ads Banner 1" class="img-fluid mt-2"
                        style="max-height: 200px; width: 100%; object-fit: cover;">
                    </div>
                  </div>
                  <% } %>


                    <% } else { %>
                      <div class="col-12">
                        <p class="text-center">No posts available.</p>
                      </div>
                      <% } %>

                      
                        

        </div>
          

      </div>
      

      <!-- Sidebar -->
      <div class="col-12 col-lg-4">
        <div class="sticky-top" style="top: 60px;">
          <div class="bg-light p-3 mb-3">Sidebar</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer Ad -->








  <script>
    var socket = io();
    socket.on('newPost', function (data) {
      console.log('New post received:', data);
      var imageSrc = data.image ? data.image : 'https://dummyimage.com/600x400/000/fff';
      var html = ``;
      html += `
            <div class="col-12 col-md-6 mb-4 ">
              <div class="card h-100 ">
                <img src="${imageSrc}" class="card-img-top img-fluid" alt="Post Image"
                  style="height: 250px; object-fit: cover;">
                <div class="card-body">
                  <h5>
                    ${data.title.substring(0, 70)}
                  </h5>
                  <p>
                    ${data.content.substring(0, 90)}...
                      <a href="/post/${data._id}" class="btn btn-link">Read More</a>
                  </p>
                </div>
              </div>
            </div>  
        `
      $('#runpost').prepend(html);
    });

  </script>
  <script>

  </script>

  <%-include('./parcials/footer.ejs') %>